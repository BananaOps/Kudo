# Copy this file to .env and fill in the values — never commit .env
PORT=8080
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=kudo

# ── Slack ─────────────────────────────────────────────────────────────────────
# Found in your Slack app settings → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Required only when the bot needs to post messages in Slack.
# Obtained after installing the app to a workspace (OAuth & Permissions → Bot Token).
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# ── Sign in with Slack (OAuth) ────────────────────────────────────────────────
# Required to enable "Sign in with Slack" in the web dashboard.
# Found in your Slack app settings → Basic Information → App Credentials.
# SLACK_CLIENT_ID=12345678.98765432
# SLACK_CLIENT_SECRET=your_client_secret_here

# Secret used to sign session cookies. Change this in production!
# SESSION_SECRET=change-me-in-production

# Public URL of the app — used to build the OAuth redirect URI.
# APP_URL=https://kudo.your-domain.com

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated Slack user IDs that can access the admin panel.
# When left empty, everyone is considered admin (dev mode).
# ADMIN_USER_IDS=U12345678,U87654321

# ── Dev / demo identity ────────────────────────────────────────────────────────
# Used when SLACK_CLIENT_ID is not set (local dev without Slack OAuth).
# The dev UserSelector lets you switch between users in the browser.
# DEFAULT_WORKSPACE_ID=W001
# DEFAULT_USER_ID=U001
# DEFAULT_USER_NAME=Alex
