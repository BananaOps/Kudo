# Copy this file to .env and fill in the values — never commit .env
PORT=8080
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=kudo

# ── Slack ─────────────────────────────────────────────────────────────────────
# Found in your Slack app settings → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Required only when the bot needs to post messages in Slack.
# Obtained after installing the app to a workspace (OAuth & Permissions → Bot Token).
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here
